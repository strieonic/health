# SERVER PORT
PORT=8000

# DATABASE (Replace with your MongoDB Atlas URI)
MONGO_URI=mongodb://localhost:27017/arogyam

# AUTHENTICATION
JWT_SECRET=your_super_secret_jwt_key_123456

# CLOUDINARY (Get these from your Cloudinary Dashboard)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# EMAIL OTP (Resend or Gmail)
EMAIL_SERVICE=resend
EMAIL_API_KEY=your_resend_api_key
EMAIL_FROM=onboarding@resend.dev

# FRONTEND URL (For CORS - e.g., https://arogyam.vercel.app)
FRONTEND_URL=http://localhost:5173
